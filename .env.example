# STADIO National Sports Day — Firebase configuration
#
# Copy this file to `.env.local` and fill in the values from your Firebase
# project (Project settings → General → Your apps → SDK setup & config).
#
# IMPORTANT: while these vars are ABSENT the app runs in LOCAL DEMO MODE,
# reading the bundled seed data so the Viewer is fully testable with no
# backend. The moment all VITE_FIREBASE_* vars are present the app switches
# to LIVE Firestore with real-time listeners and offline persistence.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# The event document id everything is scoped under (events/{eventId}).
VITE_EVENT_ID=national-sports-day-2026
